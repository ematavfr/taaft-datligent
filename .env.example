# GMAIL Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# DEEPL Configuration (Optional if using LLM for translation)
DEEPL_API_KEY=your-deepl-key

# NOTION Configuration (taaft-prompt integration)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API (for enrichment — translation FR + tags)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taaft

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3002

# Alerting — Slack incoming webhook URL (optional)
SLACK_WEBHOOK_URL=

# Scheduler — time (UTC) for daily ingestion
SCHEDULE_TIME=08:30

# DB Updater — days to keep processed SQL files
RETENTION_DAYS=90
